---
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="fixed top-0 w-full bg-white dark:bg-sand-dark border-b border-stone-200 dark:border-stone-800 z-50"
>
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/images/logo.png" alt="Guia648" class="h-12 w-auto" />
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="/"
        class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        Inicio
      </a>
      <a
        href="/directorio/turismo"
        class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        Turismo
      </a>
      <a
        href="/directorio/gastronomia"
        class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        Gastronomía
      </a>
      <a
        href="/directorio/salud"
        class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        Salud
      </a>
      <a
        href="/directorio/servicios"
        class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        Servicios
      </a>
      <ThemeToggle />
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-stone-600 dark:text-stone-300"
      aria-label="Abrir menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white dark:bg-sand-dark border-t border-stone-200 dark:border-stone-800"
  >
    <div class="px-4 py-3 space-y-2">
      <a
        href="/"
        class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        🏠 Inicio
      </a>
      <a
        href="/directorio/turismo"
        class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        🏨 Turismo
      </a>
      <a
        href="/directorio/gastronomia"
        class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        🍽️ Gastronomía
      </a>
      <a
        href="/directorio/salud"
        class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        ❤️ Salud
      </a>
      <a
        href="/directorio/servicios"
        class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors"
      >
        🔧 Servicios
      </a>
      <div class="pt-2 border-t border-stone-200 dark:border-stone-700">
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
</script>
