---
import { Sun, Moon } from '@lucide/astro';
---

<button
  class="theme-toggle p-2 rounded-lg hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors"
  type="button"
  aria-label="Toggle dark mode"
>
  <Sun class="w-5 h-5 hidden dark:block" />
  <Moon class="w-5 h-5 block dark:hidden" />
</button>

<script is:inline>
  // Initialize theme on load
  (function initTheme() {
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = savedTheme || (prefersDark ? 'dark' : 'light');
    
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    }
    localStorage.setItem('theme', theme);
  })();

  // Toggle function - using event delegation on document
  function handleThemeToggle(e) {
    if (e.target.closest('.theme-toggle')) {
      const element = document.documentElement;
      const isDark = element.classList.contains('dark');
      
      if (isDark) {
        element.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        element.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }
  }

  // Use event delegation - more reliable
  document.addEventListener('click', handleThemeToggle);
</script>
