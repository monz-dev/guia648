---
interface Props {
  businessSlug: string;
}

const { businessSlug } = Astro.props;

// Get Supabase config at build time
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<div 
  id="reviews-section" 
  class="mt-12 border-t border-stone-200 dark:border-stone-700 pt-8"
  data-slug={businessSlug}
  data-supabase-url={supabaseUrl}
  data-supabase-key={supabaseAnonKey}
>
  <h2 class="text-2xl font-bold text-stone-900 dark:text-white mb-6">
    Reseñas
  </h2>
  
  <!-- Rating Summary -->
  <div class="flex items-center gap-4 mb-8">
    <div class="flex items-center gap-2">
      <span id="rating-average" class="text-4xl font-bold text-stone-900 dark:text-white">0</span>
      <div class="flex flex-col">
        <div class="flex gap-0.5" id="rating-stars">
          {[1, 2, 3, 4, 5].map((star) => (
            <svg 
              class="w-5 h-5 text-stone-300 dark:text-stone-600"
              id={`star-${star}`}
              fill="currentColor" 
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span id="review-count" class="text-sm text-stone-500 dark:text-stone-400">
          0 reseñas
        </span>
      </div>
    </div>
  </div>
  
  <!-- Loading State -->
  <div id="reviews-loading" class="text-center py-8">
    <p class="text-stone-500 dark:text-stone-400">Cargando reseñas...</p>
  </div>
  
  <!-- Reviews List -->
  <div id="reviews-container" class="hidden">
    <p class="text-stone-500 dark:text-stone-400 text-center py-8">
      No hay reseñas todavía. ¡Sé el primero en dejar una!
    </p>
  </div>
</div>

<script is:inline>
  (function() {
    var section = document.getElementById('reviews-section');
    if (!section) return;

    var slug = section.dataset.slug;
    var url = section.dataset.supabaseUrl;
    var key = section.dataset.supabaseKey;

    if (!slug || !url || !key) {
      console.error('Missing config');
      return;
    }

    // Simple Supabase REST API call
    var container = document.getElementById('reviews-container');
    var loading = document.getElementById('reviews-loading');
    var avgEl = document.getElementById('rating-average');
    var countEl = document.getElementById('review-count');

    fetch(url + '/rest/v1/businesses?select=id&slug=eq.' + slug, {
      headers: {
        'apikey': key,
        'Authorization': 'Bearer ' + key
      }
    })
    .then(function(res) { return res.json(); })
    .then(function(businesses) {
      if (!businesses || businesses.length === 0) {
        if (loading) loading.classList.add('hidden');
        return;
      }
      var businessId = businesses[0].id;
      
      return fetch(
        url + '/rest/v1/reviews?select=*&business_id=eq.' + businessId + '&approved=eq.true&order=created_at.desc',
        {
          headers: {
            'apikey': key,
            'Authorization': 'Bearer ' + key
          }
        }
      );
    })
    .then(function(res) { return res ? res.json() : null; })
    .then(function(reviews) {
      if (loading) loading.classList.add('hidden');
      if (container) container.classList.remove('hidden');
      
      if (!reviews || reviews.length === 0) {
        if (container) {
          container.innerHTML = '<p class="text-stone-500 dark:text-stone-400 text-center py-8">No hay reseñas todavía. ¡Sé el primero en dejar una!</p>';
        }
        return;
      }

      var total = reviews.reduce(function(s, r) { return s + r.rating; }, 0);
      var avg = (total / reviews.length).toFixed(1);
      
      if (avgEl) avgEl.textContent = avg;
      if (countEl) countEl.textContent = reviews.length + ' reseñas';

      var rounded = Math.round(Number(avg));
      for (var i = 1; i <= 5; i++) {
        var star = document.getElementById('star-' + i);
        if (star) {
          if (i <= rounded) {
            star.classList.remove('text-stone-300', 'dark:text-stone-600');
            star.classList.add('text-yellow-400');
          } else {
            star.classList.remove('text-yellow-400');
            star.classList.add('text-stone-300', 'dark:text-stone-600');
          }
        }
      }

      if (container) {
        container.innerHTML = reviews.map(function(r) {
          var date = new Date(r.created_at).toLocaleDateString('es-MX', {
            year: 'numeric', month: 'short', day: 'numeric'
          });
          var stars = '';
          for (var j = 1; j <= 5; j++) {
            stars += '<svg class="w-4 h-4 ' + (j <= r.rating ? 'text-yellow-400' : 'text-stone-300 dark:text-stone-600') + '" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>';
          }
          var div = document.createElement('div');
          div.className = 'p-4 rounded-lg bg-stone-50 dark:bg-stone-800/50';
          var headerDiv = document.createElement('div');
          headerDiv.className = 'flex items-center justify-between mb-2';
          var authorDiv = document.createElement('div');
          authorDiv.className = 'flex items-center gap-2';
          var authorNameSpan = document.createElement('span');
          authorNameSpan.className = 'font-medium text-stone-900 dark:text-white';
          authorNameSpan.textContent = r.author_name;
          var starsDiv = document.createElement('div');
          starsDiv.className = 'flex gap-0.5';
          starsDiv.innerHTML = stars;
          authorDiv.appendChild(authorNameSpan);
          authorDiv.appendChild(starsDiv);
          var timeEl = document.createElement('time');
          timeEl.className = 'text-sm text-stone-400';
          timeEl.textContent = date;
          headerDiv.appendChild(authorDiv);
          headerDiv.appendChild(timeEl);
          var commentP = document.createElement('p');
          commentP.className = 'text-stone-600 dark:text-stone-300';
          commentP.textContent = r.comment;
          div.appendChild(headerDiv);
          div.appendChild(commentP);
          return div.outerHTML;
        }).join('');
      }
    })
    .catch(function(err) {
      console.error('Error loading reviews:', err);
      if (loading) loading.classList.add('hidden');
    });
  })();
</script>
