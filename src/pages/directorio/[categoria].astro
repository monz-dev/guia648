---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BusinessList from '../../components/BusinessList.astro';
import Footer from '../../components/Footer.astro';
import { getCategories, getBusinesses, getBusinessesByCategory, type Business, type Category } from '../../lib/data';

export async function getStaticPaths() {
  const categories = await getCategories();
  const businesses = await getBusinesses();
  
  return categories.map((category) => {
    const categoryBusinesses = businesses.filter((b) => b.category === category.slug);
    return {
      params: { categoria: category.slug },
      props: { 
        category,
        businesses: categoryBusinesses
      },
    };
  });
}

const { category, businesses } = Astro.props;

const categoryDescriptions: Record<string, string> = {
  turismo: "Hoteles, atractivos turísticos y actividades en Camargo, Chihuahua.",
  gastronomia: "Restaurantes, cafeterías y gastronomía local en Camargo, Chihuahua.",
  salud: "Farmacias, clínicas y servicios de salud en Camargo, Chihuahua.",
  servicios: "Talleres, profesionistas y servicios diversos en Camargo, Chihuahua."
};

const pageDescription = categoryDescriptions[category.slug] || `Negocios de ${category.name} en Camargo, Chihuahua.`;
---

<BaseLayout title={`${category.name}`} description={pageDescription}>
  <main class="pt-24 pb-16 px-4 max-w-7xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-white mb-2">
        {category.name}
      </h1>
      <p class="text-stone-600 dark:text-stone-400">
        {businesses.length} {businesses.length === 1 ? 'negocio' : 'negocios'} encontrados
      </p>
    </div>

    <BusinessList businesses={businesses} categoryName={category.name} />
  </main>

  <Footer />
</BaseLayout>
