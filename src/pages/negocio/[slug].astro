---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getBusinesses, getCategories, type Business, type Category } from '../../lib/data';

export async function getStaticPaths() {
  const businesses = await getBusinesses();
  const categories = await getCategories();
  
  return businesses.map((business) => {
    const category = categories.find((c) => c.name === business.category);
    return {
      params: { slug: business.slug },
      props: { 
        business,
        category,
      },
    };
  });
}

const { business, category, reviews } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Camargo",
    "addressRegion": "Chihuahua",
    "addressCountry": "MX"
  },
  "telephone": business.phone ? `+52${business.phone}` : undefined,
  "url": `https://guia648.com/negocio/${business.slug}`,
  "image": business.logo_url,
  "priceRange": "$$",
  "openingHours": "Mo-Su",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 27.69,
    "longitude": -105.49
  },
  "areaServed": {
    "@type": "City",
    "name": "Camargo"
  },
  "category": category?.name
};

const pageDescription = `${business.name} - ${category?.name || 'Negocio'} en Camargo, Chihuahua. ${business.description || 'Visítanos en Guia648.com'}`;
---

<BaseLayout title={business.name} description={pageDescription} image={business.logo_url || undefined}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="fixed top-0 w-full bg-white dark:bg-sand-dark border-b border-stone-200 dark:border-stone-800 z-50">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-primary dark:text-accent">
        Guia648
      </a>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center gap-4">
        <a href="/" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Inicio
        </a>
        <a href="/directorio/turismo" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Turismo
        </a>
        <a href="/directorio/gastronomia" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Gastronomía
        </a>
        <a href="/directorio/salud" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Salud
        </a>
        <a href="/directorio/servicios" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Servicios
        </a>
        <ThemeToggle />
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-600 dark:text-stone-300" aria-label="Abrir menú">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-sand-dark border-t border-stone-200 dark:border-stone-800">
      <div class="px-4 py-3 space-y-2">
        <a href="/" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🏠 Inicio
        </a>
        <a href="/directorio/turismo" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🏨 Turismo
        </a>
        <a href="/directorio/gastronomia" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🍽️ Gastronomía
        </a>
        <a href="/directorio/salud" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          ❤️ Salud
        </a>
        <a href="/directorio/servicios" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🔧 Servicios
        </a>
        <div class="pt-2 border-t border-stone-200 dark:border-stone-700">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </header>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });

    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  </script>

  <main class="pt-24 pb-16 px-4 max-w-4xl mx-auto">
    <div class="bg-white dark:bg-stone-800 rounded-2xl border border-stone-200 dark:border-stone-700 overflow-hidden">
      {business.logo_url && (
        <div class="aspect-video w-full bg-stone-200 dark:bg-stone-700">
          <img 
            src={business.logo_url} 
            alt={business.name}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <div class="p-6 md:p-8">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-stone-900 dark:text-white mb-2">
              {business.name}
            </h1>
            {category && (
              <a 
                href={`/directorio/${category.slug}`}
                class="text-sm text-primary dark:text-accent hover:underline"
              >
                {category.name}
              </a>
            )}
          </div>
        </div>

        <p class="text-stone-600 dark:text-stone-300 mb-8 text-lg">
          {business.description}
        </p>

        <div class="grid gap-4">
          {business.phone && (
            <a
              href={`tel:${business.phone}`}
              class="flex items-center gap-3 p-4 rounded-xl bg-stone-100 dark:bg-stone-700 hover:bg-primary/10 dark:hover:bg-accent-dark/10 transition-colors"
            >
              <span class="text-xl">📞</span>
              <span class="font-medium text-stone-900 dark:text-white">{business.phone}</span>
            </a>
          )}

          {business.whatsapp && (
            <a
              href={`https://wa.me/52${business.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 p-4 rounded-xl bg-green-500/10 hover:bg-green-500/20 transition-colors"
            >
              <span class="text-xl">💬</span>
              <span class="font-medium text-green-700 dark:text-green-400">WhatsApp</span>
            </a>
          )}

          {business.address && (
            <div class="flex items-center gap-3 p-4 rounded-xl bg-stone-100 dark:bg-stone-700">
              <span class="text-xl">📍</span>
              <span class="text-stone-900 dark:text-white">{business.address}</span>
            </div>
          )}

          {business.google_maps_url && (
            <a
              href={business.google_maps_url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 p-4 rounded-xl bg-blue-500/10 hover:bg-blue-500/20 transition-colors"
            >
              <span class="text-xl">🗺️</span>
              <span class="font-medium text-blue-700 dark:text-blue-400">Ver en Google Maps</span>
            </a>
          )}
        </div>

        <!-- Claim Business Button -->
        <div class="mt-8 pt-6 border-t border-stone-200 dark:border-stone-700">
          <a
            href={`https://admin-guia648.vercel.app/auth/claim/${business.slug}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl border-2 border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-300 hover:border-primary dark:hover:border-accent hover:text-primary dark:hover:text-accent transition-colors font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Soy el dueño de este negocio
          </a>
          <p class="text-xs text-stone-500 dark:text-stone-400 text-center mt-2">
            Gestiona tu información en nuestro panel de administración
          </p>
        </div>
      </div>
    </div>
  </main>

  <footer class="py-8 px-4 bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto text-center">
      <p class="mb-2">© 2024 Guia648 - Directorio Digital de Camargo, Chihuahua</p>
      <p class="text-sm">Conectando residentes y turistas con los mejores comercios locales</p>
    </div>
  </footer>
</BaseLayout>
