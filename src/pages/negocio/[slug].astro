---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewList from '../../components/ReviewList.astro';
import ReviewForm from '../../components/ReviewForm.astro';
import { getBusinesses, getCategories, type Business, type Category } from '../../lib/data';

export async function getStaticPaths() {
  const businesses = await getBusinesses();
  const categories = await getCategories();
  
  return businesses.map((business) => {
    const category = categories.find((c) => c.slug === business.category);
    return {
      params: { slug: business.slug },
      props: { 
        business,
        category,
      },
    };
  });
}

const { business, category } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Camargo",
    "addressRegion": "Chihuahua",
    "addressCountry": "MX"
  },
  "telephone": business.phone ? `+52${business.phone}` : undefined,
  "url": `https://guia648.com/negocio/${business.slug}`,
  "image": business.logo_url,
  "priceRange": "$$",
  "openingHours": "Mo-Su",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 27.69,
    "longitude": -105.49
  },
  "areaServed": {
    "@type": "City",
    "name": "Camargo"
  },
  "category": category?.name
};

const pageDescription = `${business.name} - ${category?.name || 'Negocio'} en Camargo, Chihuahua. ${business.description || 'Visítanos en Guia648.com'}`;
const businessSlug = business.slug;
const businessId = business.id;
---

<BaseLayout title={business.name} description={pageDescription} image={business.logo_url || undefined}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="pt-24 pb-16 px-4 max-w-4xl mx-auto" id="business-container">
    <div class="bg-white dark:bg-stone-800 rounded-2xl border border-stone-200 dark:border-stone-700 overflow-hidden">
      <div id="business-logo"></div>
      <div class="p-6 md:p-8">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h1 id="business-name" class="text-2xl md:text-3xl font-bold text-stone-900 dark:text-white mb-2">
              <span class="animate-pulse bg-stone-200 dark:bg-stone-700 h-8 w-64 rounded"></span>
            </h1>
            <a id="business-category-link" href="#" class="text-sm text-primary dark:text-accent hover:underline">
              <span class="animate-pulse bg-stone-200 dark:bg-stone-700 h-4 w-24 rounded inline-block"></span>
            </a>
          </div>
        </div>

        <p id="business-description" class="text-stone-600 dark:text-stone-300 mb-8 text-lg">
          <span class="animate-pulse bg-stone-200 dark:bg-stone-700 h-6 w-full rounded block mb-2"></span>
          <span class="animate-pulse bg-stone-200 dark:bg-stone-700 h-6 w-3/4 rounded block"></span>
        </p>

        <div id="business-contact" class="grid gap-4"></div>

        <div id="business-reviews">
          <ReviewList businessSlug={businessSlug} />
          <ReviewForm businessSlug={businessSlug} businessId={businessId} />
        </div>

        <div class="mt-8 pt-6 border-t border-stone-200 dark:border-stone-700">
          <a
            id="claim-button"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl border-2 border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-300 hover:border-primary dark:hover:border-accent hover:text-primary dark:hover:text-accent transition-colors font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Soy el dueño de este negocio
          </a>
          <p class="text-xs text-stone-500 dark:text-stone-400 text-center mt-2">
            Gestiona tu información en nuestro panel de administración
          </p>
        </div>
      </div>
    </div>
  </main>

  <footer class="py-8 px-4 bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto text-center">
      <p class="mb-2">© 2024 Guia648 - Directorio Digital de Camargo, Chihuahua</p>
      <p class="text-sm">Conectando residentes y turistas con los mejores comercios locales</p>
    </div>
  </footer>

  <script define:vars={{ businessSlug, businessId }}>
    function escapeAttr(str) {
      return String(str).replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function escapeText(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    async function loadBusinessData() {
      try {
        const apiUrl = window.location.hostname === 'localhost' 
          ? `http://localhost:8000/api/business.php?slug=${businessSlug}`
          : `/api/business.php?slug=${businessSlug}`;
        
        const response = await fetch(apiUrl);
        if (!response.ok) throw new Error('Failed to load');
        
        const data = await response.json();
        const { business, category } = data;

        document.title = business.name;
        
        const nameEl = document.getElementById('business-name');
        if (nameEl) {
          nameEl.textContent = business.name;
        }

        const categoryLink = document.getElementById('business-category-link');
        if (categoryLink && category) {
          categoryLink.href = `/directorio/${category.slug}`;
          categoryLink.textContent = category.name;
        }

        const description = document.getElementById('business-description');
        if (description) {
          description.textContent = business.description || '';
        }

        const contactContainer = document.getElementById('business-contact');
        if (contactContainer) {
          let html = '';
          
          if (business.phone) {
            html += `
              <a href="tel:${business.phone}" class="flex items-center gap-3 p-4 rounded-xl bg-stone-100 dark:bg-stone-700 hover:bg-primary/10 dark:hover:bg-accent-dark/10 transition-colors">
                <span class="text-xl">📞</span>
                <span class="font-medium text-stone-900 dark:text-white">${business.phone}</span>
              </a>`;
          }
          
          if (business.whatsapp) {
            html += `
              <a href="https://wa.me/52${business.whatsapp}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 rounded-xl bg-green-500/10 hover:bg-green-500/20 transition-colors">
                <span class="text-xl">💬</span>
                <span class="font-medium text-green-700 dark:text-green-400">WhatsApp</span>
              </a>`;
          }
          
          if (business.address) {
            html += `
              <div class="flex items-center gap-3 p-4 rounded-xl bg-stone-100 dark:bg-stone-700">
                <span class="text-xl">📍</span>
                <span class="text-stone-900 dark:text-white">${escapeText(business.address)}</span>
              </div>`;
          }
          
          if (business.google_maps_url) {
            html += `
              <a href="${escapeAttr(business.google_maps_url)}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 rounded-xl bg-blue-500/10 hover:bg-blue-500/20 transition-colors">
                <span class="text-xl">🗺️</span>
                <span class="font-medium text-blue-700 dark:text-blue-400">Ver en Google Maps</span>
              </a>`;
          }
          
          contactContainer.innerHTML = html;
        }

        const logoContainer = document.getElementById('business-logo');
        if (logoContainer && business.logo_url) {
          logoContainer.innerHTML = `
            <div class="aspect-video w-full bg-stone-200 dark:bg-stone-700">
              <img src="${business.logo_url}" alt="${business.name}" class="w-full h-full object-cover" />
            </div>`;
        }

        const claimButton = document.getElementById('claim-button');
        if (claimButton) {
          claimButton.href = `https://admin-guia648-d46v.vercel.app/auth/claim/${business.slug}`;
        }

        document.getElementById('business-reviews')?.setAttribute('data-slug', business.slug);
        document.getElementById('business-reviews')?.setAttribute('data-id', business.id);

      } catch (error) {
        console.error('Error loading business data:', error);
      }
    }

    loadBusinessData();
  </script>
</BaseLayout>
