---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryIcon from "../components/icons/CategoryIcon.astro";
import { getCategories, getBusinesses } from "../lib/data";

const categories = await getCategories();
const businesses = await getBusinesses();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Guia648 - Directorio de Camargo",
  description:
    "Directorio digital de comercios y servicios de Camargo, Chihuahua. Encuentra turismo, gastronomía, salud y más.",
  url: "https://guia648.com",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://guia648.com/buscar?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
  areaServed: {
    "@type": "City",
    name: "Camargo",
    addressRegion: "Chihuahua",
    addressCountry: "MX",
  },
};
---

<BaseLayout
  title="Inicio"
  description="Directorio digital de Camargo, Chihuahua. Encuentra turismo, gastronomía, salud y servicios locales."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main>
    <!-- Hero Section -->
    <section
      class="relative h-[60vh] md:h-[70vh] min-h-[400px] md:min-h-[500px] flex items-center justify-center overflow-hidden"
    >
      <!-- Hero Image -->
      <div class="absolute inset-0">
        <img
          src="/images/hero/hero.webp"
          alt="Camargo, Chihuahua"
          class="w-full h-full object-cover"
        />
        <!-- Overlay -->
        <div class="absolute inset-0 bg-black/40 md:bg-black/50"></div>
      </div>

      <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-bold mb-3 md:mb-4 text-white drop-shadow-lg"
        >
          Descubre Camargo
        </h1>
        <p
          class="text-base md:text-lg lg:text-xl mb-6 md:mb-8 text-white/90 drop-shadow-md"
        >
          El directorio de comercios y servicios locales
        </p>

        <!-- Search Bar -->
        <form
          action="/buscar"
          method="get"
          class="flex flex-col sm:flex-row gap-2 sm:gap-2 max-w-xl mx-auto"
        >
          <input
            type="search"
            name="q"
            placeholder="Buscar: nuts, restaurant, pharmacy..."
            class="flex-1 px-4 py-3 rounded-lg border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-800 text-stone-900 dark:text-white placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-accent text-base"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-primary dark:bg-accent-dark text-white font-semibold rounded-lg hover:bg-primary-dark dark:hover:bg-accent transition-colors whitespace-nowrap"
          >
            Buscar
          </button>
        </form>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="py-16 px-4 max-w-7xl mx-auto">
      <h2
        class="text-2xl md:text-3xl font-bold text-center mb-12 text-stone-900 dark:text-white"
      >
        Explora por Categoría
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          categories.map((category) => (
            <a
              href={`/directorio/${category.slug}`}
              class="p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all text-center"
            >
              <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-primary/10 dark:bg-accent-dark/10 flex items-center justify-center">
                <CategoryIcon
                  icon={category.icon || "map"}
                  class="w-6 h-6 text-primary dark:text-accent"
                />
              </div>
              <h3 class="font-semibold text-stone-900 dark:text-white">
                {category.name}
              </h3>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Featured Businesses -->
    <section class="py-16 px-4 bg-stone-100 dark:bg-stone-900">
      <div class="max-w-7xl mx-auto">
        <h2
          class="text-2xl md:text-3xl font-bold text-center mb-12 text-stone-900 dark:text-white"
        >
          Negocios Destacados
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            businesses
              .filter((b) => b.featured)
              .map((business) => (
                <a
                  href={`/negocio/${business.slug}`}
                  class="block p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all"
                >
                  <div class="aspect-video rounded-lg bg-stone-200 dark:bg-stone-700 mb-4 flex items-center justify-center">
                    {business.logo_url ? (
                      <img
                        src={business.logo_url}
                        alt={business.name}
                        class="w-full h-full object-cover rounded-lg"
                      />
                    ) : (
                      <span class="text-stone-400">Sin imagen</span>
                    )}
                  </div>
                  <h3 class="font-bold text-lg text-stone-900 dark:text-white mb-2">
                    {business.name}
                  </h3>
                  <p class="text-sm text-stone-600 dark:text-stone-400 line-clamp-2">
                    {business.description}
                  </p>
                  {business.phone && (
                    <span class="mt-3 inline-flex items-center text-sm text-primary dark:text-accent">
                      📞 {business.phone}
                    </span>
                  )}
                </a>
              ))
          }
        </div>
      </div>
    </section>
  </main>

  <footer class="py-8 px-4 bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto text-center">
      <p class="mb-2">
        © 2024 Guia648 - Directorio Digital de Camargo, Chihuahua
      </p>
      <p class="text-sm">
        Conectando residentes y turistas con los mejores comercios locales
      </p>
    </div>
  </footer>
</BaseLayout>
