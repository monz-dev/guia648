---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import categoriesData from '../data/categories/categories.json';
import businessesData from '../data/businesses/businesses.json';

const categories = categoriesData;
const businesses = businessesData;
---

<BaseLayout title="Inicio">
  <header class="fixed top-0 w-full bg-white/80 dark:bg-sand-dark/80 backdrop-blur-md z-50 border-b border-stone-200 dark:border-stone-800">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-primary dark:text-accent">
        Guia648
      </a>
      
      <div class="flex items-center gap-4">
        <a href="/directorio/turismo" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Turismo
        </a>
        <a href="/directorio/gastronomia" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Gastronomía
        </a>
        <a href="/directorio/salud" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Salud
        </a>
        <a href="/directorio/servicios" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Servicios
        </a>
        <ThemeToggle />
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center bg-gradient-to-br from-primary/20 to-secondary/20 dark:from-primary-dark/20 dark:to-secondary-dark/20">
      <!-- Placeholder for Camargo background image -->
      <div class="absolute inset-0 bg-stone-300 dark:bg-stone-800">
        <div class="absolute inset-0 flex items-center justify-center text-stone-500 dark:text-stone-400">
          <span class="text-lg">Imagen de Camargo (El Faro / La Presa)</span>
        </div>
      </div>
      
      <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-bold mb-4 text-stone-900 dark:text-white">
          Descubre Camargo
        </h1>
        <p class="text-lg md:text-xl mb-8 text-stone-700 dark:text-stone-200">
          El directorio de comercios y servicios locales
        </p>
        
        <!-- Search Bar -->
        <form action="/buscar" method="get" class="flex gap-2 max-w-xl mx-auto">
          <input
            type="search"
            name="q"
            placeholder="Buscar: nuts, restaurant, pharmacy..."
            class="flex-1 px-4 py-3 rounded-lg border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-800 text-stone-900 dark:text-white placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-accent"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-primary dark:bg-accent-dark text-white font-semibold rounded-lg hover:bg-primary-dark dark:hover:bg-accent transition-colors"
          >
            Buscar
          </button>
        </form>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="py-16 px-4 max-w-7xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-stone-900 dark:text-white">
        Explora por Categoría
      </h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((category) => (
          <a
            href={`/directorio/${category.slug}`}
            class="p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all text-center"
          >
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-primary/10 dark:bg-accent-dark/10 flex items-center justify-center">
              <span class="text-2xl">{category.icon === 'map' ? '🗺️' : category.icon === 'utensils' ? '🍽️' : category.icon === 'heart-pulse' ? '❤️' : '🔧'}</span>
            </div>
            <h3 class="font-semibold text-stone-900 dark:text-white">{category.name}</h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Featured Businesses -->
    <section class="py-16 px-4 bg-stone-100 dark:bg-stone-900">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-stone-900 dark:text-white">
          Negocios Destacados
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {businesses.filter(b => b.featured).map((business) => (
            <a
              href={`/negocio/${business.slug}`}
              class="block p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all"
            >
              <div class="aspect-video rounded-lg bg-stone-200 dark:bg-stone-700 mb-4 flex items-center justify-center">
                {business.logo_url ? (
                  <img src={business.logo_url} alt={business.name} class="w-full h-full object-cover rounded-lg" />
                ) : (
                  <span class="text-stone-400">Sin imagen</span>
                )}
              </div>
              <h3 class="font-bold text-lg text-stone-900 dark:text-white mb-2">{business.name}</h3>
              <p class="text-sm text-stone-600 dark:text-stone-400 line-clamp-2">{business.description}</p>
              {business.phone && (
                <a href={`tel:${business.phone}`} class="mt-3 inline-flex items-center text-sm text-primary dark:text-accent hover:underline">
                  📞 {business.phone}
                </a>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="py-8 px-4 bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto text-center">
      <p class="mb-2">© 2024 Guia648 - Directorio Digital de Camargo, Chihuahua</p>
      <p class="text-sm">Conectando residentes y turistas con los mejores comercios locales</p>
    </div>
  </footer>
</BaseLayout>
