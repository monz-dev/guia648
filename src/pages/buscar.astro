---
import BaseLayout from '../layouts/BaseLayout.astro';
import BusinessCard from '../components/BusinessCard.astro';
import Footer from '../components/Footer.astro';
import { getCategories, getBusinesses } from '../lib/data';

const categories = await getCategories();
const businesses = await getBusinesses();

const query = Astro.url.searchParams.get('q') || '';
const categoryFilter = Astro.url.searchParams.get('categoria') || 'all';

const pageDescription = query
  ? `Resultados de búsqueda para "${query}" en Camargo, Chihuahua`
  : "Buscar negocios, restaurantes, hoteles, servicios y más en Camargo, Chihuahua";
---

<BaseLayout title="Buscar" description={pageDescription}>
  <main class="pt-24 pb-16 px-4 max-w-7xl mx-auto min-h-screen">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-white mb-4">
        Buscar Negocios
      </h1>
      
      <!-- Search Form -->
      <div class="relative">
        <input
          type="search"
          id="search-input"
          name="q"
          value={query}
          placeholder="Buscar: nuts, restaurant, pharmacy..."
          class="w-full md:w-auto md:min-w-[300px] px-4 py-3 rounded-lg border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-800 text-stone-900 dark:text-white placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-accent"
          autofocus
        />
      </div>
      
      <!-- Category Filters -->
      <div class="mt-4 flex flex-wrap gap-2">
        <button
          class="filter-btn active px-3 py-1.5 rounded-full text-sm font-medium border transition-colors"
          data-category="all"
        >
          Todos
        </button>
        {categories.map((category) => (
          <button
            class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-400 hover:border-primary dark:hover:border-accent transition-colors"
            data-category={category.slug}
          >
            {category.name}
          </button>
        ))}
      </div>
    </div>
    
    <!-- Results Section -->
    <div id="results">
      <p class="text-stone-600 dark:text-stone-400 mb-6" id="results-count" style="display: none;">
        Buscando...
      </p>

      <div id="results-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Results populated by JavaScript -->
      </div>

      <div id="no-results" class="hidden text-center py-12">
        <p class="text-xl text-stone-600 dark:text-stone-400 mb-4">
          No se encontraron negocios
        </p>
        <p class="text-stone-500 dark:text-stone-500">
          Intenta con otros términos de búsqueda
        </p>
      </div>
    </div>

    <!-- All Businesses (shown when no query) -->
    {!query && (
      <div>
        <h2 class="text-2xl font-bold text-stone-900 dark:text-white mb-6">
          Todos los Negocios
        </h2>
        <div id="all-businesses" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {businesses.map((business) => (
            <BusinessCard
              name={business.name}
              slug={business.slug}
              description={business.description}
              phone={business.phone}
              logo_url={business.logo_url}
              featured={business.featured}
            />
          ))}
        </div>
      </div>
    )}
  </main>

  <Footer />

  <script define:vars={{ businesses }}>
    window.__SEARCH_BUSINESSES__ = businesses;
  </script>

  <!-- Search Script - Real-time search with filters -->
  <script type="module">
    import { normalizeString, scoreMatch, searchBusinesses as doSearch, escapeHtml, highlightMatches, debounce } from '../lib/search-client.js';
    
    const businesses = window.__SEARCH_BUSINESSES__;
    delete window.__SEARCH_BUSINESSES__;

    // Get query from URL parameter (more reliable than define:vars)
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q') || '';

    /**
     * Validate that a URL is safe (http/https only)
     */
    function isSafeUrl(url) {
      try {
        const parsed = new URL(url);
        return parsed.protocol === 'http:' || parsed.protocol === 'https:';
      } catch {
        return false;
      }
    }

    /**
     * Render a single business card with highlighting
     */
    function renderBusinessCard(business, query) {
      const searchTerms = query ? query.split(/\s+/).filter(Boolean) : [];
      const highlightedName = searchTerms.length > 0 ? highlightMatches(business.name, searchTerms) : business.name;
      const highlightedDesc = searchTerms.length > 0 ? highlightMatches(business.description || '', searchTerms) : (business.description || '');
      const logoUrl = business.logo_url && isSafeUrl(business.logo_url) ? business.logo_url : null;

      return `
        <a href="/negocio/${business.slug}" class="block p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all">
          <div class="aspect-video rounded-lg bg-stone-200 dark:bg-stone-700 mb-4 flex items-center justify-center overflow-hidden">
            ${
              logoUrl
                ? `<img src="${logoUrl}" alt="${business.name}" class="w-full h-full object-cover rounded-lg" loading="lazy" />`
                : `<span class="text-stone-400 text-sm">Sin imagen</span>`
            }
          </div>
          <h3 class="font-bold text-lg text-stone-900 dark:text-white mb-2">${highlightedName}</h3>
          <p class="text-sm text-stone-600 dark:text-stone-400 line-clamp-2">${highlightedDesc}</p>
          ${business.phone ? `<div class="mt-3 inline-flex items-center text-sm text-primary dark:text-accent">📞 ${business.phone}</div>` : ''}
        </a>
      `;
    }

    // Current state
    let currentQuery = '';
    let currentCategory = 'all';

    /**
     * Perform the actual search and update results display
     * @param {boolean} isInitialSearch - Whether this is the initial search from URL parameter
     */
    function performSearch(isInitialSearch = false) {
      console.log('🔎 performSearch called, isInitialSearch:', isInitialSearch, 'currentQuery:', currentQuery);

      const searchInput = document.getElementById('search-input');
      const resultsList = document.getElementById('results-list');
      const resultsCount = document.getElementById('results-count');
      const noResults = document.getElementById('no-results');
      const allBusinesses = document.getElementById('all-businesses');

      // For initial search from URL, use currentQuery (already set)
      // For live search while typing, read from input field
      if (!isInitialSearch && searchInput) {
        currentQuery = searchInput.value || '';
      }

      console.log('📊 Final query to search:', currentQuery);

      // Update URL without reload (only for live search, not initial)
      if (!isInitialSearch) {
        const url = new URL(window.location.href);
        if (currentQuery) {
          url.searchParams.set('q', currentQuery);
        } else {
          url.searchParams.delete('q');
        }
        window.history.replaceState({}, '', url);
      }

      const results = doSearch(currentQuery, currentCategory, businesses);
      console.log('📈 Search results:', results.length, 'businesses found');

      if (results.length === 0) {
        console.log('❌ No results found');
        resultsList.innerHTML = '';
        if (resultsCount) resultsCount.classList.add('hidden');
        if (noResults) noResults.classList.remove('hidden');
        if (allBusinesses) allBusinesses.classList.add('hidden');
        return;
      }

      console.log('✅ Showing results');
      if (resultsCount) {
        resultsCount.textContent = `${results.length} ${results.length === 1 ? 'resultado' : 'resultados'}`;
        resultsCount.classList.remove('hidden');
      }
      if (noResults) noResults.classList.add('hidden');
      if (allBusinesses) allBusinesses.classList.add('hidden');

      resultsList.innerHTML = results.map(r => renderBusinessCard(r.item, currentQuery)).join('');
    }

    // Debounced search (300ms delay) - ONLY ONE listener
    // Wrap to prevent the event from being passed to performSearch
    const debouncedSearch = debounce(() => performSearch(false), 300);

    /**
     * Initialize event listeners (called when DOM is ready)
     */
    function initializeEventListeners() {
      const searchInput = document.getElementById('search-input');
      const filterButtons = document.querySelectorAll('.filter-btn');

      // Search input event - ONLY debounced input listener
      if (searchInput) {
        searchInput.addEventListener('input', debouncedSearch);
        // Add enter key listener to trigger search immediately
        searchInput.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            performSearch(false); // false = not initial search
          }
        });
      }

      // Category filter buttons
      filterButtons.forEach(btn => {
        btn.addEventListener('click', function () {
          // Update active state
          filterButtons.forEach(b => {
            b.classList.remove('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
            b.classList.add('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');
          });

          this.classList.add('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
          this.classList.remove('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');

          currentCategory = this.dataset.category;
          performSearch();
        });
      });

      // Set initial active filter button
      const activeBtn = document.querySelector('.filter-btn[data-category="all"]');
      if (activeBtn) {
        activeBtn.classList.add('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
        activeBtn.classList.remove('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');
      }
    }

    // If query exists on page load, perform search immediately (client-side)
    // This ensures search works even if server-side rendering fails
    console.log('🚀 Page loaded. query:', query, 'businesses:', businesses?.length || 0, 'URL:', window.location.href);
    
    if (query) {
      currentQuery = query;
      console.log('📍 Query detected:', query, '-> setting currentQuery');
      // Show results section, hide all businesses section
      document.getElementById('results-count').style.display = 'block';
      document.getElementById('all-businesses').parentElement.style.display = 'none';
      // Execute search
      performSearch(true); // true = is initial search
      initializeEventListeners();
    } else {
      // No query, show all businesses, hide results section
      console.log('📍 No query detected, showing all businesses');
      document.getElementById('results-count').style.display = 'none';
      document.getElementById('all-businesses').parentElement.style.display = 'block';
      initializeEventListeners();
    }
  </script>
</BaseLayout>
