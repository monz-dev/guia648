---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import BusinessCard from '../components/BusinessCard.astro';
import categoriesData from '../data/categories/categories.json';
import businessesData from '../data/businesses/businesses.json';

const categories = categoriesData;
const businesses = businessesData;

const query = Astro.url.searchParams.get('q') || '';

const pageDescription = query 
  ? `Resultados de búsqueda para "${query}" en Camargo, Chihuahua`
  : "Buscar negocios, restaurantes, hoteles, servicios y más en Camargo, Chihuahua";
---

<BaseLayout title="Buscar" description={pageDescription}>
  <header class="fixed top-0 w-full bg-white/80 dark:bg-sand-dark/80 backdrop-blur-md z-50 border-b border-stone-200 dark:border-stone-800">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-primary dark:text-accent">
        Guia648
      </a>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center gap-4">
        <a href="/" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Inicio
        </a>
        <a href="/directorio/turismo" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Turismo
        </a>
        <a href="/directorio/gastronomia" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Gastronomía
        </a>
        <a href="/directorio/salud" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Salud
        </a>
        <a href="/directorio/servicios" class="text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          Servicios
        </a>
        <ThemeToggle />
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-600 dark:text-stone-300" aria-label="Abrir menú">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-sand-dark border-t border-stone-200 dark:border-stone-800">
      <div class="px-4 py-3 space-y-2">
        <a href="/" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🏠 Inicio
        </a>
        <a href="/directorio/turismo" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🏨 Turismo
        </a>
        <a href="/directorio/gastronomia" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🍽️ Gastronomía
        </a>
        <a href="/directorio/salud" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          ❤️ Salud
        </a>
        <a href="/directorio/servicios" class="block py-2 text-sm font-medium hover:text-primary dark:hover:text-accent transition-colors">
          🔧 Servicios
        </a>
        <div class="pt-2 border-t border-stone-200 dark:border-stone-700">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </header>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });

    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  </script>

  <main class="pt-24 pb-16 px-4 max-w-7xl mx-auto min-h-screen">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-white mb-4">
        Buscar Negocios
      </h1>
      
      <!-- Search Form -->
      <div class="relative">
        <input
          type="search"
          id="search-input"
          name="q"
          value={query}
          placeholder="Buscar: nuts, restaurant, pharmacy..."
          class="w-full md:w-auto md:min-w-[300px] px-4 py-3 rounded-lg border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-800 text-stone-900 dark:text-white placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-primary dark:focus:ring-accent"
          autofocus
        />
      </div>
      
      <!-- Category Filters -->
      <div class="mt-4 flex flex-wrap gap-2">
        <button
          class="filter-btn active px-3 py-1.5 rounded-full text-sm font-medium border transition-colors"
          data-category="all"
        >
          Todos
        </button>
        {categories.map((category) => (
          <button
            class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-400 hover:border-primary dark:hover:border-accent transition-colors"
            data-category={category.slug}
          >
            {category.name}
          </button>
        ))}
      </div>
    </div>
    
    <!-- Results Section -->
    <div id="results">
      {query && (
        <p class="text-stone-600 dark:text-stone-400 mb-6" id="results-count">
          Buscando...
        </p>
      )}
      
      <div id="results-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Results populated by JavaScript -->
      </div>

      {query && (
        <div id="no-results" class="hidden text-center py-12">
          <p class="text-xl text-stone-600 dark:text-stone-400 mb-4">
            No se encontraron negocios para "{query}"
          </p>
          <p class="text-stone-500 dark:text-stone-500">
            Intenta con otros términos de búsqueda
          </p>
        </div>
      )}
    </div>

    <!-- All Businesses (shown when no query) -->
    {!query && (
      <div>
        <h2 class="text-2xl font-bold text-stone-900 dark:text-white mb-6">
          Todos los Negocios
        </h2>
        <div id="all-businesses" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {businesses.map((business) => (
            <BusinessCard
              name={business.name}
              slug={business.slug}
              description={business.description}
              phone={business.phone}
              logo_url={business.logo_url}
              featured={business.featured}
            />
          ))}
        </div>
      </div>
    )}
  </main>

  <footer class="py-8 px-4 bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto text-center">
      <p class="mb-2">© 2024 Guia648 - Directorio Digital de Camargo, Chihuahua</p>
      <p class="text-sm">Conectando residentes y turistas con los mejores comercios locales</p>
    </div>
  </footer>

  <!-- Search Script - Real-time search with filters -->
  <script is:inline define:vars={{ query, businesses, categories }}>
    // Debounce function to limit search execution
    function debounce(func, wait) {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }

    // Fuzzy search implementation
    function fuzzyMatch(text, pattern) {
      if (!pattern) return { match: true, score: 0 };
      
      text = text.toLowerCase();
      pattern = pattern.toLowerCase();
      
      // Exact match
      if (text.includes(pattern)) {
        return { match: true, score: 1 - (pattern.length / text.length) };
      }
      
      // Check for partial word matches
      const textWords = text.split(/\s+/);
      const patternWords = pattern.split(/\s+/);
      
      let matchedWords = 0;
      for (const pw of patternWords) {
        for (const tw of textWords) {
          if (tw.includes(pw) || pw.includes(tw)) {
            matchedWords++;
            break;
          }
        }
      }
      
      if (matchedWords > 0) {
        return { match: true, score: (matchedWords / patternWords.length) * 0.5 };
      }
      
      // Fuzzy character match (typo tolerance)
      let patternIdx = 0;
      let consecutiveMatches = 0;
      
      for (let i = 0; i < text.length && patternIdx < pattern.length; i++) {
        if (text[i] === pattern[patternIdx]) {
          consecutiveMatches++;
          patternIdx++;
        } else if (consecutiveMatches > 0) {
          consecutiveMatches--;
        }
      }
      
      const fuzzyThreshold = Math.floor(pattern.length * 0.7);
      if (patternIdx >= fuzzyThreshold) {
        return { match: true, score: 0.3 };
      }
      
      return { match: false, score: 0 };
    }

    function searchBusinesses(searchQuery, categoryFilter) {
      // If no query and no filter, return all
      if ((!searchQuery || searchQuery.trim() === '') && categoryFilter === 'all') {
        return businesses.map(b => ({ item: b, score: 1 }));
      }
      
      const results = [];
      const searchTerms = searchQuery ? searchQuery.toLowerCase().split(/\s+/).filter(Boolean) : [];
      
      for (const business of businesses) {
        // Filter by category first
        if (categoryFilter !== 'all' && business.category !== categoryFilter) {
          continue;
        }
        
        // If no search query, just add filtered businesses
        if (searchTerms.length === 0) {
          results.push({ item: business, score: 1 });
          continue;
        }
        
        // Search across name, description, category
        const searchableText = [
          business.name,
          business.description || '',
          business.category,
        ].filter(Boolean).join(' ');
        
        let bestScore = 0;
        
        for (const term of searchTerms) {
          const result = fuzzyMatch(searchableText, term);
          if (result.match) {
            bestScore = Math.max(bestScore, result.score);
          }
        }
        
        if (bestScore > 0) {
          results.push({ item: business, score: bestScore });
        }
      }
      
      // Sort by score descending
      results.sort((a, b) => b.score - a.score);
      return results;
    }

    function highlightMatch(text, query) {
      if (!query || !text) return text;
      
      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      let result = text;
      
      terms.forEach(term => {
        const regex = new RegExp(`(${term})`, 'gi');
        result = result.replace(regex, '<mark class="bg-primary/20 dark:bg-accent-dark/20 px-0.5 rounded">$1</mark>');
      });
      
      return result;
    }

    function renderBusinessCard(business, query) {
      const highlightedName = highlightMatch(business.name, query);
      const highlightedDesc = highlightMatch(business.description || '', query);
      
      return `
        <a href="/negocio/${business.slug}" class="block p-6 rounded-xl bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 hover:border-primary dark:hover:border-accent hover:shadow-lg transition-all">
          <div class="aspect-video rounded-lg bg-stone-200 dark:bg-stone-700 mb-4 flex items-center justify-center overflow-hidden">
            ${business.logo_url 
              ? `<img src="${business.logo_url}" alt="${business.name}" class="w-full h-full object-cover rounded-lg" loading="lazy" />`
              : `<span class="text-stone-400 text-sm">Sin imagen</span>`
            }
          </div>
          <h3 class="font-bold text-lg text-stone-900 dark:text-white mb-2">${highlightedName}</h3>
          <p class="text-sm text-stone-600 dark:text-stone-400 line-clamp-2">${highlightedDesc}</p>
          ${business.phone ? `<div class="mt-3 inline-flex items-center text-sm text-primary dark:text-accent">📞 ${business.phone}</div>` : ''}
        </a>
      `;
    }

    // Current state
    let currentQuery = '';
    let currentCategory = 'all';

    function performSearch() {
      const searchInput = document.getElementById('search-input');
      const resultsList = document.getElementById('results-list');
      const resultsCount = document.getElementById('results-count');
      const noResults = document.getElementById('no-results');
      const allBusinesses = document.getElementById('all-businesses');
      
      // Get current values
      currentQuery = searchInput?.value || '';
      
      // Update URL without reload
      const url = new URL(window.location.href);
      if (currentQuery) {
        url.searchParams.set('q', currentQuery);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState({}, '', url);
      
      const results = searchBusinesses(currentQuery, currentCategory);
      
      if (results.length === 0) {
        resultsList.innerHTML = '';
        if (resultsCount) resultsCount.classList.add('hidden');
        if (noResults) noResults.classList.remove('hidden');
        if (allBusinesses) allBusinesses.classList.add('hidden');
        return;
      }
      
      if (resultsCount) {
        resultsCount.textContent = `${results.length} ${results.length === 1 ? 'resultado' : 'resultados'}`;
        resultsCount.classList.remove('hidden');
      }
      if (noResults) noResults.classList.add('hidden');
      if (allBusinesses) allBusinesses.classList.add('hidden');
      
      resultsList.innerHTML = results.map(r => renderBusinessCard(r.item, currentQuery)).join('');
    }

    // Debounced search (300ms delay)
    const debouncedSearch = debounce(performSearch, 300);

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      const searchInput = document.getElementById('search-input');
      const filterButtons = document.querySelectorAll('.filter-btn');
      
      // Search input event
      if (searchInput) {
        searchInput.addEventListener('input', function() {
          debouncedSearch();
        });
        
        // Also update results immediately on keyup for responsiveness
        searchInput.addEventListener('keyup', function() {
          // Instant search for better UX
          performSearch();
        });
      }
      
      // Category filter buttons
      filterButtons.forEach(btn => {
        btn.addEventListener('click', function() {
          // Update active state
          filterButtons.forEach(b => {
            b.classList.remove('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
            b.classList.add('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');
          });
          
          this.classList.add('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
          this.classList.remove('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');
          
          currentCategory = this.dataset.category;
          performSearch();
        });
      });
      
      // Set initial active filter button
      const activeBtn = document.querySelector('.filter-btn[data-category="all"]');
      if (activeBtn) {
        activeBtn.classList.add('active', 'bg-primary', 'dark:bg-accent-dark', 'text-white', 'border-primary', 'dark:border-accent');
        activeBtn.classList.remove('border-stone-300', 'dark:border-stone-600', 'text-stone-600', 'dark:text-stone-400');
      }
      
      // Initial search if query exists
      if (query) {
        performSearch();
      }
    });
  </script>
</BaseLayout>
